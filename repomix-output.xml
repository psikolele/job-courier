        print(html[:500])
    else:
        print("HTML Snippet returned (first 1000 chars):")
        print(html[:1000])
        print("HTML Snippet returned (last 1000 chars):")
        print(html[-1000:])
except Exception as e:
    print(f"Error fetching JobRoom: {e}")
