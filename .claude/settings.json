{
  "$schema": "https://claude.com/schema/settings.json",
  "model": "claude-haiku-4-5-20251001",
  "name": "Job_Courier - Marketplace Platform",
  "context": "React job marketplace with complex filtering, search, and job matching. CRITICAL: Filter caching, search debounce, pagination, parallel API calls. Meeting notes + video recordings track progress. Status: URGENT (deadline March 27, April 10 follow-ups).",
  "priorities": [
    "token-optimization",
    "filter-caching",
    "search-debounce",
    "pagination",
    "parallel-apis",
    "urgent-deadline"
  ],
  "tokenBudget": {
    "session": 50000,
    "monthly": 400000,
    "byFeature": {
      "filtering_logic": 15000,
      "search_pagination": 10000,
      "matching_algorithm": 12000,
      "ui_ux": 8000,
      "testing": 3000,
      "buffer": 2000
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_ROOT}/.claude/hooks/session-start.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "gitConfig": {
    "commitTemplate": "{{action}}: {{description}}\n\nWhy: {{reason}}\nHow: {{details}}\nImpact: {{impact}} tokens saved",
    "actions": [
      "Add",
      "Optimize",
      "Fix",
      "Cache",
      "Batch",
      "Refactor",
      "Docs"
    ]
  },
  "excludePatterns": [
    "node_modules/",
    "dist/",
    ".env.local",
    "*.mp4",
    "*.docx"
  ]
}
